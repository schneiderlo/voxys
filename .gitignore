# ═══════════════════════════════════════════════════════════════════════════════
# voxy .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Build directories
# ─────────────────────────────────────────────────────────────────────────────
build/
build-*/
out/
cmake-build-*/

# ─────────────────────────────────────────────────────────────────────────────
# CMake generated files
# ─────────────────────────────────────────────────────────────────────────────
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
*.cmake
!cmake/*.cmake
compile_commands.json

# ─────────────────────────────────────────────────────────────────────────────
# IDE and Editor files
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────────────────────
# Compiled binaries
# ─────────────────────────────────────────────────────────────────────────────
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll
*.exe
*.out
*.app

# ─────────────────────────────────────────────────────────────────────────────
# WASM outputs
# ─────────────────────────────────────────────────────────────────────────────
*.wasm
*.js.mem
*.data

# ─────────────────────────────────────────────────────────────────────────────
# Third-party dependencies (fetched separately)
# ─────────────────────────────────────────────────────────────────────────────
third_party/glm/
third_party/zstd/
third_party/glfw/
third_party/stb/
third_party/dawn/
third_party/googletest/
third_party/wgpu-native/
third_party/emsdk/

# ─────────────────────────────────────────────────────────────────────────────
# Testing
# ─────────────────────────────────────────────────────────────────────────────
Testing/
CTestTestfile.cmake

# ─────────────────────────────────────────────────────────────────────────────
# Debug files
# ─────────────────────────────────────────────────────────────────────────────
*.dSYM/
*.pdb

# ─────────────────────────────────────────────────────────────────────────────
# bazel
# ─────────────────────────────────────────────────────────────────────────────

bazel-*
.emscripten_cache/
third_party/x11_headers/


.venv/

# Generated terrain imports can be very large.
data/generated/
